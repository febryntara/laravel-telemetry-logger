{
    "name": "febryntara/laravel-telemetry-logger",
    "description": "Comprehensive Laravel activity logger: all routes, requests, sessions, errors, with sensitive data filtering and microservice forwarding.",
    "keywords": ["laravel", "logging", "telemetry", "activity-log", "request-log", "microservice"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "I Gede Bagus Febryntara",
            "email": "paglutgede@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "illuminate/bus": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Febryntara\\TelemetryLogger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Febryntara\\TelemetryLogger\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Febryntara\\TelemetryLogger\\TelemetryLoggerServiceProvider"
            ],
            "aliases": {
                "TelemetryLogger": "Febryntara\\TelemetryLogger\\Facades\\TelemetryLogger"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
